#:import NoTransition kivy.uix.screenmanager.NoTransition
#:import theme dmccodegui.theme_manager.theme

# Root layout: StatusBar + TabBar + ScreenManager

<RootLayout@BoxLayout>:
    orientation: 'vertical'
    canvas.before:
        Color:
            rgba: theme.bg_dark
        Rectangle:
            pos: self.pos
            size: self.size
    StatusBar:
        id: status_bar
        size_hint_y: None
        height: '64dp'
    TabBar:
        id: tab_bar
        size_hint_y: None
        height: '64dp'
    ScreenManager:
        id: sm
        transition: NoTransition()
        SetupScreen:
            name: 'setup'
        RunScreen:
            name: 'run'
        AxesSetupScreen:
            name: 'axes_setup'
        ParametersScreen:
            name: 'parameters'
        ProfilesScreen:
            name: 'profiles'
        DiagnosticsScreen:
            name: 'diagnostics'
