#:import NoTransition kivy.uix.screenmanager.NoTransition
#:import theme dmccodegui.theme_manager.theme

# Root layout: StatusBar + TabBar + ScreenManager

<RootLayout@BoxLayout>:
    orientation: 'vertical'
    canvas.before:
        Color:
            rgba: theme.bg_dark
        Rectangle:
            pos: self.pos
            size: self.size
    StatusBar:
        id: status_bar
        size_hint_y: None
        height: '64dp'
    # Setup badge: visible only when controller is in SETUP state
    Label:
        id: setup_badge
        text: 'SETUP MODE'
        size_hint_y: None
        height: '0dp'
        opacity: 0
        bold: True
        font_size: '17sp'
        color: 0, 0, 0, 1
        halign: 'center'
        valign: 'middle'
        text_size: self.size
        canvas.before:
            Color:
                rgba: 1, 0.85, 0, 1
            Rectangle:
                pos: self.pos
                size: self.size
    TabBar:
        id: tab_bar
        size_hint_y: None
        height: '64dp'
    ScreenManager:
        id: sm
        transition: NoTransition()
        SetupScreen:
            name: 'setup'
        # Machine-specific screens (run, axes_setup, parameters) are added
        # programmatically by DMCApp._add_machine_screens() from the registry.
        ProfilesScreen:
            name: 'profiles'
        UsersScreen:
            name: 'users'
