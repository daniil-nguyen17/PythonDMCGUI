# Styles for rectangular buttons/toggles used on Buttons & Switches screen

<RectButton@Button>:
    size_hint: None, None
    width: '120dp'
    height: '44dp'
    background_normal: ''
    background_down: ''
    background_color: 0, 0, 0, 0
    color: 0.886, 0.910, 0.941, 1
    font_size: '16sp'
    canvas.before:
        Color:
            rgba: (0.118, 0.145, 0.188, 1) if self.state == 'down' else (0.071, 0.094, 0.133, 1)
        RoundedRectangle:
            pos: self.x, self.y
            size: self.width, self.height
            radius: [8,]
        Color:
            rgba: 0.118, 0.145, 0.188, 1
        Line:
            rounded_rectangle: (self.x, self.y, self.width, self.height, 8)
            width: 2.0

<ToggleRect@ToggleButton>:
    size_hint: None, None
    width: '120dp'
    height: '44dp'
    background_normal: ''
    background_down: ''
    background_color: 0, 0, 0, 0
    font_size: '16sp'
    color: (0.133, 0.773, 0.369, 1) if self.state == 'down' else (0.886, 0.910, 0.941, 1)
    canvas.before:
        Color:
            rgba: (0.071, 0.094, 0.133, 1) if self.state == 'down' else (0.051, 0.071, 0.102, 1)
        RoundedRectangle:
            pos: self.x, self.y
            size: self.width, self.height
            radius: [8,]
        Color:
            rgba: (0.133, 0.773, 0.369, 1) if self.state == 'down' else (1.0, 0.2, 0.2, 1)
        Line:
            rounded_rectangle: (self.x, self.y, self.width, self.height, 8)
            width: 3.6 if self.state == 'down' else 3.0


<ButtonsSwitchesScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: '12dp'
        spacing: '12dp'

        Label:
            size_hint_y: None
            height: '40dp'
            text: 'Switches and Buttons'
            font_size: '18sp'

        # Row of 8 action buttons, horizontally centered
        AnchorLayout:
            size_hint_y: None
            height: '64dp'
            anchor_x: 'center'
            anchor_y: 'center'
            BoxLayout:
                size_hint: None, None
                width: self.minimum_width
                height: '100dp'
                spacing: '24dp'
                padding: '8dp'
                RectButton:
                    text: 'Cancel Mai Dao'
                RectButton:
                    text: 'Them Da'
                RectButton:
                    text: 'Bot Da'
                RectButton:
                    text: 'Bat Dau Mai'
                RectButton:
                    text: 'Luu Lai Rest point'
                RectButton:
                    text: 'Luu Lai Start point'
                RectButton:
                    text: 'Di Ve Rest Cho 4 Truc'
                RectButton:
                    text: 'Di Ve Start Cho 4 Truc'

        # Row of 8 toggles, horizontally centered
        AnchorLayout:
            size_hint_y: None
            height: '64dp'
            anchor_x: 'center'
            anchor_y: 'center'
            BoxLayout:
                size_hint: None, None
                width: self.minimum_width
                height: '100dp'
                spacing: '24dp'
                padding: '8dp'
                ToggleRect:
                    text: 'Enter Setup'
                ToggleRect:
                    text: 'Probing Mode'
                ToggleRect:
                    text: 'Chay Wheeler'
                ToggleRect:
                    text: 'Switch 4'
                ToggleRect:
                    text: 'Switch 5'
                ToggleRect:
                    text: 'Switch 6'
                ToggleRect:
                    text: 'Switch 7'
                ToggleRect:
                    text: 'Switch 8'

        # Axis Sliders Section
        Label:
            size_hint_y: None
            height: '30dp'
            text: 'Axis Position Control'
            font_size: '14sp'
            bold: True

        ScrollView:
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: '12dp'
                padding: '8dp'

                # A Axis
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: '80dp'
                    spacing: '4dp'
                    
                    BoxLayout:
                        size_hint_y: None
                        height: '24dp'
                        spacing: '8dp'
                        Label:
                            text: 'A Axis:'
                            size_hint_x: None
                            width: '80dp'
                            font_size: '12sp'
                        Slider:
                            id: slider_a
                            min: -1000
                            max: 1000
                            value: 0
                            on_touch_up: root.on_slider_release('A', self.value)
                        TextInput:
                            id: value_a_display
                            text: '0'
                            readonly: True
                            multiline: False
                            size_hint_x: None
                            width: '80dp'
                            height: '24dp'
                            font_size: '12sp'
                            halign: 'center'
                            background_color: (0.031, 0.047, 0.071, 1)
                            foreground_color: (0.886, 0.910, 0.941, 1)
                    
                    BoxLayout:
                        size_hint_y: None
                        height: '20dp'
                        spacing: '12dp'
                        Label:
                            text: 'Reverse Limit'
                            size_hint_x: None
                            width: '120dp'
                            font_size: '10sp'
                        CheckBox:
                            id: a_reverse_limit
                            size_hint_x: None
                            width: '30dp'
                            active: False
                        Label:
                            text: 'Home'
                            size_hint_x: None
                            width: '60dp'
                            font_size: '10sp'
                        CheckBox:
                            id: a_home
                            size_hint_x: None
                            width: '30dp'
                            active: False
                        Label:
                            text: 'Forward Limit'
                            size_hint_x: None
                            width: '120dp'
                            font_size: '10sp'
                        CheckBox:
                            id: a_forward_limit
                            size_hint_x: None
                            width: '30dp'
                            active: False
                        Label:
                            text: 'Motor Off'
                            size_hint_x: None
                            width: '80dp'
                            font_size: '10sp'
                        CheckBox:
                            id: a_motor_off
                            size_hint_x: None
                            width: '30dp'
                            active: False

                # B Axis
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: '80dp'
                    spacing: '4dp'
                    
                    BoxLayout:
                        size_hint_y: None
                        height: '24dp'
                        spacing: '8dp'
