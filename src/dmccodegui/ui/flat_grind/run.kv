#:import theme dmccodegui.theme_manager.theme
#:import DeltaCBarChart dmccodegui.screens.flat_grind.widgets
#:import ImageButton dmccodegui.screens.flat_grind.widgets.ImageButton
#:import ARROW_UP_IMG dmccodegui.screens.flat_grind.widgets.ARROW_UP_IMG
#:import ARROW_DOWN_IMG dmccodegui.screens.flat_grind.widgets.ARROW_DOWN_IMG
#:import run_module dmccodegui.screens.flat_grind.run
#:import kivy_matplotlib_widget kivy_matplotlib_widget

<FlatGrindRunScreen>:
    canvas.before:
        Color:
            rgba: theme.bg_dark
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'

        # -----------------------------------------------------------------------
        # Disconnect banner (visible only when disconnected)
        # -----------------------------------------------------------------------
        Label:
            text: root.disconnect_banner
            font_size: '16sp'
            bold: True
            color: 1, 1, 1, 1
            size_hint_y: None
            height: '40dp' if root.disconnect_banner else '0dp'
            opacity: 1.0 if root.disconnect_banner else 0.0
            halign: 'center'
            valign: 'middle'
            text_size: self.size
            canvas.before:
                Color:
                    rgba: (0.8, 0.1, 0.1, 1) if root.disconnect_banner else (0, 0, 0, 0)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [4,]

        # -----------------------------------------------------------------------
        # Main content: LEFT (50%) + RIGHT (50%)
        # -----------------------------------------------------------------------
        BoxLayout:
            orientation: 'horizontal'
            spacing: '8dp'
            padding: ['8dp', '8dp', '8dp', '4dp']

            # ===================================================================
            # LEFT COLUMN (50%) — plot + adjustment panels
            # ===================================================================
            BoxLayout:
                size_hint_x: 0.5
                orientation: 'vertical'
                spacing: '8dp'

                # Live A/B position plot
                BoxLayout:
                    canvas.before:
                        Color:
                            rgba: theme.bg_panel
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [8,]
                        Color:
                            rgba: 0.0, 0.8, 0.8, 0.8
                        Line:
                            rounded_rectangle: (self.x, self.y, self.width, self.height, 8)
                            width: 1.4
                    size_hint_y: None
                    height: '400dp'
                    padding: ['4dp', '4dp']

                    MatplotFigure:
                        id: ab_plot
                        size_hint: 1, 1
                        do_pan_x: False
                        do_pan_y: False
                        do_scale: False
                        touch_mode: 'none'

                # Delta-C: Knife Grind Adjustment (Flat/Convex only)
                BoxLayout:
                    id: delta_c_panel
                    canvas.before:
                        Color:
                            rgba: theme.bg_panel
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [8,]
                        Color:
                            rgba: 1.0, 0.55, 0.0, 0.8
                        Line:
                            rounded_rectangle: (self.x, self.y, self.width, self.height, 8)
                            width: 1.4
                    size_hint_y: 1
                    orientation: 'vertical'
                    padding: '6dp'
                    spacing: '3dp'

                    # Header: title + controls centered below
                    BoxLayout:
                        size_hint_y: None
                        height: '28dp'
                        spacing: '8dp'

                        Label:
                            text: 'CHỈNH SỬA ĐỘ DÀY KHI MÀI DAO'
                            font_size: '16sp'
                            color: theme.text_mid
                            bold: True
                            halign: 'center'
                            text_size: self.size
                            valign: 'middle'

                    BoxLayout:
                        size_hint_y: None
                        height: '32dp'
                        spacing: '8dp'
                        padding: ['20dp', '0dp']

                        # Step size buttons (1ct / 2ct / 3ct)
                        Label:
                            text: 'STEP:'
                            font_size: '13sp'
                            color: theme.text_mid
                            size_hint_x: None
                            width: '45dp'
                            halign: 'right'
                            text_size: self.size
                            valign: 'middle'

                        Button:
                            text: '1ct'
                            size_hint_x: None
                            width: '48dp'
                            font_size: '13sp'
                            bold: True
                            background_normal: ''
                            background_color: (0.024, 0.714, 0.831, 0.8) if root.delta_c_step == 1 else (0.1, 0.12, 0.16, 1)
                            color: theme.text_main
                            on_release: root.set_delta_c_step(1)

                        Button:
                            text: '2ct'
                            size_hint_x: None
                            width: '48dp'
                            font_size: '13sp'
                            bold: True
                            background_normal: ''
                            background_color: (0.024, 0.714, 0.831, 0.8) if root.delta_c_step == 2 else (0.1, 0.12, 0.16, 1)
                            color: theme.text_main
                            on_release: root.set_delta_c_step(2)

                        Button:
                            text: '3ct'
                            size_hint_x: None
                            width: '48dp'
                            font_size: '13sp'
                            bold: True
                            background_normal: ''
                            background_color: (0.024, 0.714, 0.831, 0.8) if root.delta_c_step == 3 else (0.1, 0.12, 0.16, 1)
                            color: theme.text_main
                            on_release: root.set_delta_c_step(3)

                        Widget:

                        Label:
                            text: 'SEGMENTS:'
                            font_size: '14sp'
                            color: theme.text_mid
                            size_hint_x: None
                            width: '100dp'
                            halign: 'right'
                            text_size: self.size
                            valign: 'middle'

                        Button:
                            text: '-'
                            size_hint_x: None
                            width: '30dp'
                            font_size: '20sp'
                            background_normal: ''
                            background_color: 0.1, 0.12, 0.16, 1
                            on_release: root.on_section_count_change(root.section_count - 1)

                        Label:
                            id: section_count_label
                            text: str(root.section_count)
                            font_size: '19sp'
                            color: theme.text_main
                            bold: True
                            size_hint_x: None
                            width: '24dp'
                            halign: 'center'
                            text_size: self.size
                            valign: 'middle'

                        Button:
                            text: '+'
                            size_hint_x: None
                            width: '30dp'
                            font_size: '20sp'
                            background_normal: ''
                            background_color: 0.1, 0.12, 0.16, 1
                            on_release: root.on_section_count_change(root.section_count + 1)

                        Widget:

                    # Less grinding (subtract) — per-section arrows (flipped up)
                    BoxLayout:
                        id: adjust_down_row
                        size_hint_y: None
                        height: '40dp'
                        spacing: '2dp'

                    # Bar chart
                    DeltaCBarChart:
                        id: delta_c_chart
                        offsets: root.delta_c_offsets
                        array_size: root.delta_c_array_size
                        max_offset: 20
                        size_hint_y: 1

                    # More grinding (add) — per-section arrows (flipped down)
                    BoxLayout:
                        id: adjust_up_row
                        size_hint_y: None
                        height: '40dp'
                        spacing: '2dp'

                    # Controls row
                    BoxLayout:
                        size_hint_y: None
                        height: '38dp'
                        spacing: '8dp'

                        Label:
                            text: 'ĐÃ CHỌN: ' + root.selected_section_value + ' cts'
                            font_size: '16sp'
                            color: theme.text_main
                            halign: 'left'
                            text_size: self.size
                            valign: 'middle'
                            size_hint_x: 0.4

                        Button:
                            text: 'XÓA'
                            font_size: '18sp'
                            bold: True
                            background_normal: ''
                            background_color: 0.25, 0.08, 0.08, 1
                            color: 0.95, 0.35, 0.35, 1
                            size_hint_x: 0.25
                            on_release: root.on_clear_delta_c()

                        Button:
                            text: 'LƯU LẠI'
                            font_size: '18sp'
                            bold: True
                            background_normal: ''
                            background_color: 0.118, 0.227, 0.373, 1
                            color: 0.576, 0.773, 0.992, 1
                            size_hint_x: 0.35
                            on_release: root.on_apply_delta_c()

                # GRIND PROGRESS (below delta-C)
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: '165dp'
                    padding: ['8dp', '4dp']
                    spacing: '3dp'
                    canvas.before:
                        Color:
                            rgba: theme.bg_panel
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [8,]
                        Color:
                            rgba: 0.2, 0.9, 0.3, 0.8
                        Line:
                            rounded_rectangle: (self.x, self.y, self.width, self.height, 8)
                            width: 1.4

                    Label:
                        text: 'QUÁ TRÌNH MÀI DAO'
                        font_size: '16sp'
                        bold: True
                        color: theme.text_mid
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size
                        size_hint_y: None
                        height: '22dp'

                    GridLayout:
                        cols: 2
                        spacing: '8dp'
                        size_hint_y: 1

                        BoxLayout:
                            orientation: 'vertical'
                            Label:
                                text: 'THỜI GIAN ĐÃ CHẠY'
                                font_size: '15sp'
                                color: 0.396, 0.455, 0.545, 1
                                halign: 'left'
                                valign: 'bottom'
                                text_size: self.size
                                size_hint_y: 0.35
                            Label:
                                id: lbl_elapsed
                                text: root.cycle_elapsed
                                font_size: '27sp'
                                bold: True
                                color: theme.text_main
                                halign: 'left'
                                valign: 'top'
                                text_size: self.size
                                size_hint_y: 0.65

                        BoxLayout:
                            orientation: 'vertical'
                            Label:
                                text: 'THỜI GIAN CÒN LẠI'
                                font_size: '15sp'
                                color: 0.396, 0.455, 0.545, 1
                                halign: 'left'
                                valign: 'bottom'
                                text_size: self.size
                                size_hint_y: 0.35
                            Label:
                                id: lbl_eta
                                text: root.cycle_eta
                                font_size: '27sp'
                                bold: True
                                color: theme.text_main
                                halign: 'left'
                                valign: 'top'
                                text_size: self.size
                                size_hint_y: 0.65

                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: '24dp'
                        spacing: '8dp'

                        ProgressBar:
                            id: cycle_progress
                            min: 0
                            max: 100
                            value: root.cycle_completion_pct
                            size_hint_y: None
                            height: '12dp'
                            pos_hint: {'center_y': 0.5}

                        Label:
                            text: '{0}%'.format(int(root.cycle_completion_pct))
                            font_size: '16sp'
                            bold: True
                            color: 0.396, 0.455, 0.545, 1
                            size_hint_x: None
                            width: '44dp'
                            halign: 'right'
                            valign: 'middle'
                            text_size: self.size

                    GridLayout:
                        cols: 2
                        spacing: '8dp'
                        size_hint_y: None
                        height: '30dp'

                        BoxLayout:
                            orientation: 'horizontal'
                            spacing: '4dp'
                            Label:
                                text: 'DAO ĐÃ MÀI TRONG CA:'
                                font_size: '15sp'
                                color: 0.396, 0.455, 0.545, 1
                                halign: 'left'
                                valign: 'middle'
                                text_size: self.size
                            Label:
                                id: lbl_ses_knives
                                text: root.session_knife_count
                                font_size: '21sp'
                                bold: True
                                color: 0.235, 0.639, 0.996, 1
                                halign: 'left'
                                valign: 'middle'
                                text_size: self.size

                        BoxLayout:
                            orientation: 'horizontal'
                            spacing: '4dp'
                            Label:
                                text: 'DAO ĐÃ MÀI VỚI ĐÁ HIỆN TẠI:'
                                font_size: '15sp'
                                color: 0.396, 0.455, 0.545, 1
                                halign: 'left'
                                valign: 'middle'
                                text_size: self.size
                            Label:
                                id: lbl_stn_knives
                                text: root.stone_knife_count
                                font_size: '21sp'
                                bold: True
                                color: theme.text_main
                                halign: 'left'
                                valign: 'middle'
                                text_size: self.size

            # ===================================================================
            # RIGHT COLUMN (50%) — controller log + stone comp + grind progress
            # ===================================================================
            BoxLayout:
                size_hint_x: 0.5
                orientation: 'vertical'
                spacing: '6dp'

                # ---------------------------------------------------------------
                # CONTROLLER LOG
                # ---------------------------------------------------------------
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: 0.55
                    padding: ['8dp', '4dp']
                    spacing: '2dp'
                    canvas.before:
                        Color:
                            rgba: theme.bg_dark
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [8,]
                        Color:
                            rgba: 0.9, 0.2, 0.9, 0.8
                        Line:
                            rounded_rectangle: (self.x, self.y, self.width, self.height, 8)
                            width: 1.4

                    Label:
                        text: 'THÔNG TIN TỪ BỘ ĐIỀU KHIỂN'
                        font_size: '11sp'
                        bold: True
                        color: theme.text_mid
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size
                        size_hint_y: None
                        height: '18dp'

                    ScrollView:
                        id: mg_log_scroll
                        do_scroll_x: False

                        Label:
                            text: root.mg_log_text
                            font_size: '28sp'
                            font_name: 'Roboto'
                            color: 0.4, 0.9, 0.4, 1
                            halign: 'left'
                            valign: 'bottom'
                            text_size: self.width, None
                            size_hint_y: None
                            height: max(self.texture_size[1], mg_log_scroll.height)

                # ---------------------------------------------------------------
                # STONE COMPENSATION
                # ---------------------------------------------------------------
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: 0.45
                    padding: ['10dp', '6dp']
                    spacing: '4dp'
                    canvas.before:
                        Color:
                            rgba: theme.bg_panel
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [8,]
                        Color:
                            rgba: 0.9, 0.9, 0.2, 0.8
                        Line:
                            rounded_rectangle: (self.x, self.y, self.width, self.height, 8)
                            width: 1.4

                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: '32dp'
                        spacing: '8dp'

                        Label:
                            text: 'BÙ ĐÁ - BỚT ĐÁ BẰNG TAY'
                            font_size: '16sp'
                            bold: True
                            color: theme.text_mid
                            halign: 'left'
                            valign: 'middle'
                            text_size: self.size
                            size_hint_x: 0.5

                        Label:
                            id: start_pt_c_label
                            text: root.start_pt_c
                            font_size: '24sp'
                            bold: True
                            color: theme.text_main
                            halign: 'right'
                            valign: 'middle'
                            text_size: self.size
                            size_hint_x: 0.5

                    Button:
                        id: less_stone_btn
                        text: 'BỚT ĐÁ'
                        font_size: '18sp'
                        bold: True
                        size_hint_y: 1
                        background_normal: ''
                        background_color: 0.15, 0.08, 0.02, 1
                        color: 0.984, 0.573, 0.235, 1
                        disabled: root.motion_active
                        on_release: root.on_less_stone()

                    Button:
                        id: more_stone_btn
                        text: 'BÙ ĐÁ'
                        font_size: '18sp'
                        bold: True
                        size_hint_y: 1
                        background_normal: ''
                        background_color: 0.02, 0.12, 0.06, 1
                        color: 0.133, 0.773, 0.369, 1
                        disabled: root.motion_active
                        on_release: root.on_more_stone()

                # (Grind progress moved to left column)

        # -----------------------------------------------------------------------
        # BOTTOM ACTION BAR (full width)
        # -----------------------------------------------------------------------
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: '72dp'
            spacing: '12dp'
            padding: ['12dp', '6dp', '12dp', '6dp']

            canvas.before:
                Color:
                    rgba: theme.bg_panel
                Rectangle:
                    pos: self.pos
                    size: self.size

            Button:
                id: start_grind_btn
                text: 'BẮT ĐẦU MÀI'
                font_size: '16sp'
                bold: True
                size_hint_x: 1
                background_normal: ''
                background_color: 0.09, 0.40, 0.20, 1
                color: 0.733, 0.969, 0.827, 1
                disabled: root.motion_active
                on_release: root.on_start_grind()

            Button:
                id: shutdown_btn
                text: 'TẮT MÁY'
                font_size: '16sp'
                bold: True
                size_hint_x: 0.6
                background_normal: ''
                background_down: ''
                background_color: (0.6, 0.3, 0.0, 1)
                color: (1, 0.9, 0.7, 1)
                disabled: root.motion_active
                on_release: root.on_shutdown()
