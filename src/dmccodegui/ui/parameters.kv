#:import theme dmccodegui.theme_manager.theme

<ParametersScreen>:
    canvas.before:
        Color:
            rgba: theme.bg_dark
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'

        # ── Title bar ──────────────────────────────────────────────────────────
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: '52dp'
            padding: '12dp', '4dp'
            spacing: '8dp'
            canvas.before:
                Color:
                    rgba: theme.bg_panel
                Rectangle:
                    pos: self.pos
                    size: self.size

            Label:
                text: 'THAM SỐ'
                font_size: '28sp'
                size_hint_x: 1
                halign: 'center'
                valign: 'middle'
                text_size: self.size
                color: theme.text_main

            Button:
                text: 'ĐỌC THAM SỐ TỪ MÁY'
                size_hint_x: None
                width: '220dp'
                size_hint_y: None
                height: '44dp'
                pos_hint: {'center_y': 0.5}
                font_size: '16sp'
                on_release: root.read_from_controller()
                background_normal: ''
                background_down: ''
                background_color: theme.bg_row
                color: theme.text_main
                canvas.before:
                    Color:
                        rgba: theme.border
                    Line:
                        rounded_rectangle: (self.x, self.y, self.width, self.height, 6)
                        width: 1.2

        # ── ScrollView with dynamic cards_container ────────────────────────────
        ScrollView:
            size_hint_y: 1
            do_scroll_x: False

            BoxLayout:
                id: cards_container
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                padding: '12dp'
                spacing: '12dp'

        # ── Bottom action bar ──────────────────────────────────────────────────
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: '56dp'
            padding: '12dp', '6dp'
            spacing: '16dp'
            canvas.before:
                Color:
                    rgba: theme.bg_panel
                Rectangle:
                    pos: self.pos
                    size: self.size

            Label:
                text: f"{root.pending_count} unsaved change(s)" if root.pending_count > 0 else ""
                font_size: '16sp'
                size_hint_x: 1
                halign: 'left'
                valign: 'middle'
                text_size: self.size
                color: (0.980, 0.749, 0.043, 1)
                opacity: 1 if root.pending_count > 0 else 0

            Button:
                id: apply_btn
                text: 'ÁP DỤNG VÀO MÁY'
                size_hint_x: None
                width: '220dp'
                size_hint_y: None
                height: '44dp'
                pos_hint: {'center_y': 0.5}
                font_size: '16sp'
                bold: True
                on_release: root.apply_to_controller()
                background_normal: ''
                background_down: ''
                background_color: (0.980, 0.749, 0.043, 0.9) if root.pending_count > 0 else theme.bg_row
                color: (0.031, 0.047, 0.071, 1) if root.pending_count > 0 else theme.text_mid
                canvas.before:
                    Color:
                        rgba: theme.border
                    Line:
                        rounded_rectangle: (self.x, self.y, self.width, self.height, 6)
                        width: 1.2
