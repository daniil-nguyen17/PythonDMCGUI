# ParametersScreen placeholder
#:import theme dmccodegui.theme_manager.theme

<ParametersScreen>:
    canvas.before:
        Color:
            rgba: theme.bg_dark
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: 'vertical'
        spacing: '8dp'
        Widget:
            size_hint_y: 0.3
        Label:
            text: '= = ='
            font_size: '80sp'
            bold: True
            color: theme.text_mid
            size_hint_y: None
            height: '120dp'
            halign: 'center'
            valign: 'middle'
            text_size: self.size
        Label:
            text: 'PARAMETERS'
            color: theme.text_main
            font_size: '58sp'
            size_hint_y: None
            height: '80dp'
            halign: 'center'
            valign: 'middle'
            text_size: self.size
        Widget:
