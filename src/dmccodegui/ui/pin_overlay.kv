# PINOverlay widget rule
#:import theme dmccodegui.theme_manager.theme

<PINOverlay>:
    auto_dismiss: False
    size_hint: 1, 1
    background_color: 0, 0, 0, 0
    overlay_color: theme.overlay_bg

    AnchorLayout:
        anchor_x: 'center'
        anchor_y: 'center'

        BoxLayout:
            id: pin_card
            orientation: 'vertical'
            size_hint: None, None
            width: '540dp'
            height: self.minimum_height
            padding: '16dp'
            spacing: '8dp'
            canvas.before:
                Color:
                    rgba: theme.bg_card
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [12]

            # Lock icon
            Label:
                text: 'PIN'
                font_size: '48sp'
                bold: True
                color: 0.133, 0.773, 0.369, 1
                size_hint_y: None
                height: '64dp'
                halign: 'center'
                valign: 'middle'
                text_size: self.size

            # Username display / selector label
            Label:
                text: root.username if root.username else 'CHỌN NGƯỜI DÙNG MÁY'
                font_size: '36sp'
                color: theme.text_main
                size_hint_y: None
                height: '52dp'
                halign: 'center'
                valign: 'middle'
                text_size: self.size

            # PIN dots row
            Label:
                text: root.pin_dots
                font_size: '50sp'
                color: 0.133, 0.773, 0.369, 1
                size_hint_y: None
                height: '60dp'
                halign: 'center'
                valign: 'middle'
                text_size: self.size
                letter_spacing: 8

            # Error message
            Label:
                text: root.error_msg
                font_size: '23sp'
                color: 0.88, 0.06, 0.06, 1
                size_hint_y: None
                height: '24dp'
                halign: 'center'
                valign: 'middle'
                text_size: self.size

            # Numpad container (shown by default, hidden when user list shown)
            BoxLayout:
                id: numpad_layout
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: '4dp'

                # 3x4 numpad grid
                GridLayout:
                    cols: 3
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: '4dp'

                    # Row 1
                    Button:
                        text: '1'
                        size_hint_y: None
                        height: '80dp'
                        font_size: '43sp'
                        background_normal: ''
                        background_down: ''
                        background_color: theme.bg_row
                        color: theme.text_main
                        on_release: root.press_digit('1')
                    Button:
                        text: '2'
                        size_hint_y: None
                        height: '80dp'
                        font_size: '43sp'
                        background_normal: ''
                        background_down: ''
                        background_color: theme.bg_row
                        color: theme.text_main
                        on_release: root.press_digit('2')
                    Button:
                        text: '3'
                        size_hint_y: None
                        height: '80dp'
                        font_size: '43sp'
                        background_normal: ''
                        background_down: ''
                        background_color: theme.bg_row
                        color: theme.text_main
                        on_release: root.press_digit('3')

                    # Row 2
                    Button:
                        text: '4'
                        size_hint_y: None
                        height: '80dp'
                        font_size: '43sp'
                        background_normal: ''
                        background_down: ''
                        background_color: theme.bg_row
                        color: theme.text_main
                        on_release: root.press_digit('4')
                    Button:
                        text: '5'
                        size_hint_y: None
                        height: '80dp'
                        font_size: '43sp'
                        background_normal: ''
                        background_down: ''
                        background_color: theme.bg_row
                        color: theme.text_main
                        on_release: root.press_digit('5')
                    Button:
                        text: '6'
                        size_hint_y: None
                        height: '80dp'
                        font_size: '43sp'
                        background_normal: ''
                        background_down: ''
                        background_color: theme.bg_row
                        color: theme.text_main
                        on_release: root.press_digit('6')

                    # Row 3
                    Button:
                        text: '7'
                        size_hint_y: None
                        height: '80dp'
                        font_size: '43sp'
                        background_normal: ''
                        background_down: ''
                        background_color: theme.bg_row
                        color: theme.text_main
                        on_release: root.press_digit('7')
                    Button:
                        text: '8'
                        size_hint_y: None
                        height: '80dp'
                        font_size: '43sp'
                        background_normal: ''
                        background_down: ''
                        background_color: theme.bg_row
                        color: theme.text_main
                        on_release: root.press_digit('8')
                    Button:
                        text: '9'
                        size_hint_y: None
                        height: '80dp'
                        font_size: '43sp'
                        background_normal: ''
                        background_down: ''
                        background_color: theme.bg_row
                        color: theme.text_main
                        on_release: root.press_digit('9')

                    # Row 4
                    Button:
                        text: '<'
                        size_hint_y: None
                        height: '80dp'
                        font_size: '43sp'
                        background_normal: ''
                        background_down: ''
                        background_color: theme.bg_row
                        color: theme.text_main
                        on_release: root.press_backspace()
                    Button:
                        text: '0'
                        size_hint_y: None
                        height: '80dp'
                        font_size: '43sp'
                        background_normal: ''
                        background_down: ''
                        background_color: theme.bg_row
                        color: theme.text_main
                        on_release: root.press_digit('0')
                    Button:
                        text: 'OK'
                        size_hint_y: None
                        height: '80dp'
                        font_size: '43sp'
                        background_normal: ''
                        background_down: ''
                        background_color: 0.133, 0.773, 0.369, 1
                        color: 1, 1, 1, 1
                        bold: True
                        on_release: root.press_enter()

            # User list container (hidden by default)
            ScrollView:
                id: user_list_scroll
                size_hint_y: None
                height: '360dp'
                opacity: 0
                disabled: True

                BoxLayout:
                    id: user_list_layout
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: '4dp'

            # Switch User / Cancel row
            BoxLayout:
                orientation: 'horizontal'
                size_hint_y: None
                height: '56dp'
                spacing: '4dp'

                Button:
                    text: 'THAY NGƯỜI DÙNG'
                    font_size: '25sp'
                    background_normal: ''
                    background_down: ''
                    background_color: theme.bg_card
                    color: theme.text_mid
                    on_release: root.show_user_list()

                Button:
                    text: 'HỦY'
                    font_size: '25sp'
                    background_normal: ''
                    background_down: ''
                    background_color: theme.bg_card
                    color: theme.text_mid
                    on_release: root.cancel_user_list()
