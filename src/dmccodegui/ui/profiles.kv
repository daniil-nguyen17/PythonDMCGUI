#:import theme dmccodegui.theme_manager.theme

# ──────────────────────────────────────────────────────────────────────────────
# FileChooserOverlay
# ──────────────────────────────────────────────────────────────────────────────

<FileChooserOverlay>:
    canvas.before:
        Color:
            rgba: 0, 0, 0, 0.7
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: '16dp'
        spacing: '12dp'
        canvas.before:
            Color:
                rgba: theme.bg_panel
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: 'Select Profile CSV'
            font_size: '24sp'
            bold: True
            size_hint_y: None
            height: '48dp'
            color: theme.text_main
            halign: 'center'
            valign: 'middle'
            text_size: self.size

        FileChooserListView:
            id: chooser
            size_hint_y: 1
            font_size: '18sp'

        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: '56dp'
            spacing: '16dp'

            Button:
                text: 'Cancel'
                font_size: '18sp'
                bold: True
                background_normal: ''
                background_down: ''
                background_color: theme.bg_row
                color: theme.text_main
                on_release: root.dismiss()
                canvas.before:
                    Color:
                        rgba: theme.border
                    Line:
                        rounded_rectangle: (self.x, self.y, self.width, self.height, 6)
                        width: 1.2

            Button:
                text: 'Open'
                font_size: '18sp'
                bold: True
                background_normal: ''
                background_down: ''
                background_color: (0.133, 0.773, 0.369, 1)
                color: (0.031, 0.047, 0.071, 1)
                on_release: root.confirm_selection()


# ──────────────────────────────────────────────────────────────────────────────
# DiffDialog
# ──────────────────────────────────────────────────────────────────────────────

<DiffDialog>:
    canvas.before:
        Color:
            rgba: 0, 0, 0, 0.75
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: '16dp'
        spacing: '12dp'
        canvas.before:
            Color:
                rgba: theme.bg_panel
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: 'Import Diff — Changes to Apply'
            font_size: '22sp'
            bold: True
            size_hint_y: None
            height: '48dp'
            color: theme.text_main
            halign: 'center'
            valign: 'middle'
            text_size: self.size

        ScrollView:
            size_hint_y: 1
            do_scroll_x: False

            GridLayout:
                id: diff_grid
                cols: 3
                size_hint_y: None
                height: self.minimum_height
                spacing: '4dp'
                padding: '8dp'

        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: '56dp'
            spacing: '16dp'

            Button:
                text: 'Cancel'
                font_size: '18sp'
                bold: True
                background_normal: ''
                background_down: ''
                background_color: theme.bg_row
                color: theme.text_main
                on_release: root.dismiss()
                canvas.before:
                    Color:
                        rgba: theme.border
                    Line:
                        rounded_rectangle: (self.x, self.y, self.width, self.height, 6)
                        width: 1.2

            Button:
                text: 'Apply'
                font_size: '18sp'
                bold: True
                background_normal: ''
                background_down: ''
                background_color: (0.133, 0.773, 0.369, 1)
                color: (0.031, 0.047, 0.071, 1)
                on_release: root.apply_changes()


# ──────────────────────────────────────────────────────────────────────────────
# ProfilesScreen
# ──────────────────────────────────────────────────────────────────────────────

<ProfilesScreen>:
    canvas.before:
        Color:
            rgba: theme.bg_dark
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'

        # ── Title bar ──────────────────────────────────────────────────────────
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: '52dp'
            padding: '12dp', '4dp'
            canvas.before:
                Color:
                    rgba: theme.bg_panel
                Rectangle:
                    pos: self.pos
                    size: self.size

            Label:
                text: 'Profiles'
                font_size: '28sp'
                size_hint_x: 1
                halign: 'center'
                valign: 'middle'
                text_size: self.size
                color: theme.text_main

        # ── Main content ───────────────────────────────────────────────────────
        BoxLayout:
            orientation: 'vertical'
            padding: '40dp'
            spacing: '20dp'

            Widget:
                # Top spacer
                size_hint_y: 0.1

            # ── Export section ─────────────────────────────────────────────────
            Label:
                text: 'XUAT: Doc tham so va mang tu bo dieu khien, luu vao file CSV tren may tinh'
                font_size: '15sp'
                color: theme.text_dim
                size_hint_y: None
                height: '32dp'
                halign: 'center'
                valign: 'bottom'
                text_size: self.size

            Button:
                text: 'XUAT HO SO TU MAY'
                font_size: '24sp'
                bold: True
                size_hint_y: None
                height: '64dp'
                background_normal: ''
                background_down: ''
                background_color: (0.031, 0.314, 0.471, 1)
                color: theme.text_main
                on_release: root.on_export_press()
                canvas.before:
                    Color:
                        rgba: (0.024, 0.714, 0.831, 0.6)
                    Line:
                        rounded_rectangle: (self.x, self.y, self.width, self.height, 8)
                        width: 1.5

            # ── Separator ─────────────────────────────────────────────────────
            Widget:
                size_hint_y: None
                height: '2dp'
                canvas:
                    Color:
                        rgba: theme.border
                    Rectangle:
                        pos: self.pos
                        size: self.size

            # ── Import section ────────────────────────────────────────────────
            Label:
                text: 'NAP: Doc file CSV va GHI gia tri VAO MANG TRONG BO DIEU KHIEN (deltaA, deltaB, deltaC, deltaD)'
                font_size: '15sp'
                color: theme.text_dim
                size_hint_y: None
                height: '32dp'
                halign: 'center'
                valign: 'bottom'
                text_size: self.size

            Button:
                id: import_btn
                text: 'NAP HO SO VAO MAY' if not self.disabled else 'NAP HO SO (DANG CHAY)'
                font_size: '24sp'
                bold: True
                size_hint_y: None
                height: '64dp'
                background_normal: ''
                background_down: ''
                background_color: (0.031, 0.471, 0.188, 1) if not self.disabled else (0.2, 0.2, 0.2, 1)
                color: theme.text_main
                on_release: root.on_import_press()
                canvas.before:
                    Color:
                        rgba: (0.133, 0.773, 0.369, 0.6) if not self.disabled else (0.3, 0.3, 0.3, 0.4)
                    Line:
                        rounded_rectangle: (self.x, self.y, self.width, self.height, 8)
                        width: 1.5

            Label:
                text: 'Doc CSV > Hien thi thay doi > Ghi mang vao bo dieu khien > Xac nhan > Luu NV'
                font_size: '13sp'
                color: (0.024, 0.714, 0.831, 0.6)
                size_hint_y: None
                height: '24dp'
                halign: 'center'
                valign: 'top'
                text_size: self.size

            # ── Status label ───────────────────────────────────────────────────
            Label:
                text: root.status_text
                font_size: '17sp'
                color: (0.133, 0.773, 0.369, 1) if 'THAT BAI' not in root.status_text.upper() else (0.9, 0.3, 0.3, 1)
                size_hint_y: None
                height: '60dp'
                halign: 'center'
                valign: 'middle'
                text_size: self.size
                opacity: 1 if root.status_text else 0

            Widget:
                # Bottom spacer
