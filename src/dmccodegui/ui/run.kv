#:import theme dmccodegui.theme_manager.theme
#:import DeltaCBarChart dmccodegui.screens.run
#:import BCompBarChart dmccodegui.screens.run
#:import run_module dmccodegui.screens.run
#:import kivy_matplotlib_widget kivy_matplotlib_widget

<RunScreen>:
    canvas.before:
        Color:
            rgba: theme.bg_dark
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'

        # -----------------------------------------------------------------------
        # Disconnect banner (visible only when disconnected)
        # -----------------------------------------------------------------------
        Label:
            text: root.disconnect_banner
            font_size: '16sp'
            bold: True
            color: 1, 1, 1, 1
            size_hint_y: None
            height: '40dp' if root.disconnect_banner else '0dp'
            opacity: 1.0 if root.disconnect_banner else 0.0
            halign: 'center'
            valign: 'middle'
            text_size: self.size
            canvas.before:
                Color:
                    rgba: (0.8, 0.1, 0.1, 1) if root.disconnect_banner else (0, 0, 0, 0)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [4,]

        # -----------------------------------------------------------------------
        # Main content area (horizontal: left column + right column)
        # -----------------------------------------------------------------------
        BoxLayout:
            orientation: 'horizontal'
            spacing: '8dp'
            padding: ['8dp', '8dp', '8dp', '4dp']

            # -------------------------------------------------------------------
            # LEFT COLUMN (60%) — plot placeholder + adjustment placeholder
            # -------------------------------------------------------------------
            BoxLayout:
                size_hint_x: 0.6
                orientation: 'vertical'
                spacing: '8dp'

                # Live A/B position plot (RUN-07)
                BoxLayout:
                    canvas.before:
                        Color:
                            rgba: theme.bg_panel
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [8,]
                        Color:
                            rgba: theme.border
                        Line:
                            rounded_rectangle: (self.x, self.y, self.width, self.height, 8)
                            width: 1.2
                    size_hint_y: 1
                    padding: ['4dp', '4dp']

                    MatplotFigure:
                        id: ab_plot
                        size_hint: 1, 1
                        do_pan_x: False
                        do_pan_y: False
                        do_scale: False
                        touch_mode: 'none'

                # ---------------------------------------------------------------
                # Delta-C: Knife Grind Adjustment panel (Flat/Convex only)
                # Starts visible; hidden on Serration via _apply_machine_type_widgets
                # ---------------------------------------------------------------
                BoxLayout:
                    id: delta_c_panel
                    canvas.before:
                        Color:
                            rgba: theme.bg_panel
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [8,]
                        Color:
                            rgba: theme.border
                        Line:
                            rounded_rectangle: (self.x, self.y, self.width, self.height, 8)
                            width: 1.2
                    size_hint_y: None
                    height: '220dp'
                    orientation: 'vertical'
                    padding: '10dp'
                    spacing: '6dp'

                    # Header row: title + section count controls
                    BoxLayout:
                        size_hint_y: None
                        height: '28dp'

                        Label:
                            text: 'CHỈNH ĐỘ MÀI TRÊN DAO'
                            font_size: '11sp'
                            color: theme.text_mid
                            bold: True
                            halign: 'left'
                            text_size: self.size
                            valign: 'middle'

                        BoxLayout:
                            size_hint_x: None
                            width: '120dp'
                            spacing: '4dp'

                            Label:
                                text: 'CHIA PHẦN TRÊN DAO:'
                                font_size: '11sp'
                                color: theme.text_mid
                                size_hint_x: None
                                width: '60dp'
                                halign: 'right'
                                text_size: self.size
                                valign: 'middle'

                            Button:
                                text: '-'
                                size_hint_x: None
                                width: '24dp'
                                font_size: '14sp'
                                background_normal: ''
                                background_color: 0.1, 0.12, 0.16, 1
                                on_release: root.on_section_count_change(root.section_count - 1)

                            Label:
                                id: section_count_label
                                text: str(root.section_count)
                                font_size: '13sp'
                                color: theme.text_main
                                bold: True
                                size_hint_x: None
                                width: '20dp'
                                halign: 'center'
                                text_size: self.size
                                valign: 'middle'

                            Button:
                                text: '+'
                                size_hint_x: None
                                width: '24dp'
                                font_size: '14sp'
                                background_normal: ''
                                background_color: 0.1, 0.12, 0.16, 1
                                on_release: root.on_section_count_change(root.section_count + 1)

                    # Bar chart area
                    DeltaCBarChart:
                        id: delta_c_chart
                        offsets: root.delta_c_offsets
                        size_hint_y: None
                        height: '110dp'

                    # Controls row: selected value + up/down + apply
                    BoxLayout:
                        size_hint_y: None
                        height: '40dp'
                        spacing: '8dp'

                        # Selected section display
                        Label:
                            text: 'ĐÃ CHỌN: ' + root.selected_section_value + ' cts'
                            font_size: '12sp'
                            color: theme.text_main
                            halign: 'left'
                            text_size: self.size
                            valign: 'middle'
                            size_hint_x: 0.4

                        # Down adjustment button
                        Button:
                            text: '- ' + str(run_module.DELTA_C_STEP)
                            font_size: '13sp'
                            bold: True
                            background_normal: ''
                            background_color: 0.15, 0.08, 0.02, 1
                            color: 0.984, 0.573, 0.235, 1
                            size_hint_x: 0.2
                            on_release: root.on_adjust_down()

                        # Up adjustment button
                        Button:
                            text: '+ ' + str(run_module.DELTA_C_STEP)
                            font_size: '13sp'
                            bold: True
                            background_normal: ''
                            background_color: 0.02, 0.12, 0.06, 1
                            color: 0.133, 0.773, 0.369, 1
                            size_hint_x: 0.2
                            on_release: root.on_adjust_up()

                        # Apply button
                        Button:
                            text: 'LƯU LẠI'
                            font_size: '13sp'
                            bold: True
                            background_normal: ''
                            background_color: 0.118, 0.227, 0.373, 1
                            color: 0.576, 0.773, 0.992, 1
                            size_hint_x: 0.2
                            on_release: root.on_apply_delta_c()

                # ---------------------------------------------------------------
                # bComp: Serration Grind Adjustment panel (Serration only)
                # Starts hidden; shown on Serration via _apply_machine_type_widgets
                # ---------------------------------------------------------------
                BoxLayout:
                    id: bcomp_panel
                    canvas.before:
                        Color:
                            rgba: theme.bg_panel
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [8,]
                        Color:
                            rgba: theme.border
                        Line:
                            rounded_rectangle: (self.x, self.y, self.width, self.height, 8)
                            width: 1.2
                    size_hint_y: None
                    height: '220dp'
                    orientation: 'vertical'
                    padding: '10dp'
                    spacing: '6dp'
                    opacity: 0
                    disabled: True

                    # Header row: title
                    BoxLayout:
                        size_hint_y: None
                        height: '28dp'

                        Label:
                            text: 'BỔ SUNG MÀI CHO RĂNG CƯA'
                            font_size: '11sp'
                            color: theme.text_mid
                            bold: True
                            halign: 'left'
                            text_size: self.size
                            valign: 'middle'

                    # bComp bar chart area
                    BCompBarChart:
                        id: bcomp_chart
                        offsets: root.bcomp_offsets
                        size_hint_y: None
                        height: '110dp'

                    # Controls row: selected value + up/down + apply
                    BoxLayout:
                        size_hint_y: None
                        height: '40dp'
                        spacing: '8dp'

                        # Selected serration display
                        Label:
                            text: 'ĐÃ CHỌN: ' + root.selected_bcomp_value + ' cts'
                            font_size: '12sp'
                            color: theme.text_main
                            halign: 'left'
                            text_size: self.size
                            valign: 'middle'
                            size_hint_x: 0.4

                        # Down adjustment button
                        Button:
                            text: '- ' + str(run_module.BCOMP_STEP)
                            font_size: '13sp'
                            bold: True
                            background_normal: ''
                            background_color: 0.15, 0.08, 0.02, 1
                            color: 0.984, 0.573, 0.235, 1
                            size_hint_x: 0.2
                            on_release: root.on_bcomp_adjust_down()

                        # Up adjustment button
                        Button:
                            text: '+ ' + str(run_module.BCOMP_STEP)
                            font_size: '13sp'
                            bold: True
                            background_normal: ''
                            background_color: 0.02, 0.12, 0.06, 1
                            color: 0.133, 0.773, 0.369, 1
                            size_hint_x: 0.2
                            on_release: root.on_bcomp_adjust_up()

                        # Apply button
                        Button:
                            text: 'LƯU LẠI'
                            font_size: '13sp'
                            bold: True
                            background_normal: ''
                            background_color: 0.118, 0.227, 0.373, 1
                            color: 0.576, 0.773, 0.992, 1
                            size_hint_x: 0.2
                            on_release: root.on_apply_bcomp()

            # -------------------------------------------------------------------
            # RIGHT COLUMN (40%) — cycle status + axis positions
            # -------------------------------------------------------------------
            BoxLayout:
                size_hint_x: 0.4
                orientation: 'vertical'
                spacing: '8dp'

                # Cycle Status card
                BoxLayout:
                    canvas.before:
                        Color:
                            rgba: theme.bg_panel
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [8,]
                        Color:
                            rgba: theme.border
                        Line:
                            rounded_rectangle: (self.x, self.y, self.width, self.height, 8)
                            width: 1.2
                    size_hint_y: None
                    height: '340dp' if root.is_serration else '240dp'
                    orientation: 'vertical'
                    padding: ['10dp', '8dp']
                    spacing: '4dp'

                    # Section header
                    Label:
                        text: 'QUÁ TRÌNH MÀI DAO'
                        font_size: '11sp'
                        bold: True
                        color: theme.text_mid
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size
                        size_hint_y: None
                        height: '20dp'

                    # Serration-only fields: tooth, pass, depth
                    # opacity=0 and height=0 collapses them on non-serration machines
                    GridLayout:
                        cols: 2
                        spacing: '8dp'
                        size_hint_y: None
                        height: '96dp' if root.is_serration else '0dp'
                        opacity: 1.0 if root.is_serration else 0.0

                        # Tooth
                        BoxLayout:
                            orientation: 'vertical'
                            size_hint_y: None
                            height: '44dp'
                            Label:
                                text: 'RĂNG CƯA'
                                font_size: '10sp'
                                color: 0.396, 0.455, 0.545, 1
                                halign: 'left'
                                valign: 'bottom'
                                text_size: self.size
                            Label:
                                id: lbl_tooth
                                text: root.cycle_tooth
                                font_size: '20sp'
                                bold: True
                                color: 0.235, 0.639, 0.996, 1
                                halign: 'left'
                                valign: 'top'
                                text_size: self.size
                                opacity: 1.0 if root.cycle_running else 0.4

                        # Pass
                        BoxLayout:
                            orientation: 'vertical'
                            size_hint_y: None
                            height: '44dp'
                            Label:
                                text: 'PASS'
                                font_size: '10sp'
                                color: 0.396, 0.455, 0.545, 1
                                halign: 'left'
                                valign: 'bottom'
                                text_size: self.size
                            Label:
                                id: lbl_pass
                                text: root.cycle_pass
                                font_size: '20sp'
                                bold: True
                                color: theme.text_main
                                halign: 'left'
                                valign: 'top'
                                text_size: self.size
                                opacity: 1.0 if root.cycle_running else 0.4

                        # Depth (spans 2 cols)
                        BoxLayout:
                            orientation: 'vertical'
                            size_hint_y: None
                            height: '44dp'
                            Label:
                                text: 'ĐỘ SÂU'
                                font_size: '10sp'
                                color: 0.396, 0.455, 0.545, 1
                                halign: 'left'
                                valign: 'bottom'
                                text_size: self.size
                            Label:
                                id: lbl_depth
                                text: root.cycle_depth
                                font_size: '20sp'
                                bold: True
                                color: theme.text_main
                                halign: 'left'
                                valign: 'top'
                                text_size: self.size
                                opacity: 1.0 if root.cycle_running else 0.4

                        # Spacer cell to maintain 2-col alignment
                        Widget:
                            size_hint_y: None
                            height: '44dp'

                    # Common fields: elapsed + ETA
                    GridLayout:
                        cols: 2
                        spacing: '8dp'
                        size_hint_y: None
                        height: '56dp'

                        BoxLayout:
                            orientation: 'vertical'
                            Label:
                                text: 'THỜI GIAN ĐÃ CHẠY'
                                font_size: '10sp'
                                color: 0.396, 0.455, 0.545, 1
                                halign: 'left'
                                valign: 'bottom'
                                text_size: self.size
                            Label:
                                id: lbl_elapsed
                                text: root.cycle_elapsed
                                font_size: '20sp'
                                bold: True
                                color: theme.text_main
                                halign: 'left'
                                valign: 'top'
                                text_size: self.size
                                opacity: 1.0 if root.cycle_running else 0.4

                        BoxLayout:
                            orientation: 'vertical'
                            Label:
                                text: 'THỜI GIAN CÒN LẠI'
                                font_size: '10sp'
                                color: 0.396, 0.455, 0.545, 1
                                halign: 'left'
                                valign: 'bottom'
                                text_size: self.size
                            Label:
                                id: lbl_eta
                                text: root.cycle_eta
                                font_size: '20sp'
                                bold: True
                                color: theme.text_main
                                halign: 'left'
                                valign: 'top'
                                text_size: self.size
                                opacity: 1.0 if root.cycle_running else 0.4

                    # Progress bar + percentage label
                    BoxLayout:
                        orientation: 'vertical'
                        size_hint_y: None
                        height: '32dp'
                        spacing: '2dp'

                        ProgressBar:
                            id: cycle_progress
                            min: 0
                            max: 100
                            value: root.cycle_completion_pct
                            size_hint_y: None
                            height: '10dp'

                        Label:
                            text: '{0}% XONG'.format(int(root.cycle_completion_pct))
                            font_size: '10sp'
                            color: 0.278, 0.333, 0.412, 1
                            halign: 'left'
                            valign: 'top'
                            text_size: self.size
                            size_hint_y: None
                            height: '18dp'

                    # Knife counts (always visible)
                    GridLayout:
                        cols: 2
                        spacing: '8dp'
                        size_hint_y: None
                        height: '52dp'

                        # Session knife count
                        BoxLayout:
                            orientation: 'vertical'
                            size_hint_y: None
                            height: '44dp'
                            Label:
                                text: 'DAO ĐÃ MÀI TRONG CA'
                                font_size: '10sp'
                                color: 0.396, 0.455, 0.545, 1
                                halign: 'left'
                                valign: 'bottom'
                                text_size: self.size
                            Label:
                                id: lbl_ses_knives
                                text: root.session_knife_count
                                font_size: '20sp'
                                bold: True
                                color: 0.235, 0.639, 0.996, 1
                                halign: 'left'
                                valign: 'top'
                                text_size: self.size

                        # Stone knife count
                        BoxLayout:
                            orientation: 'vertical'
                            size_hint_y: None
                            height: '44dp'
                            Label:
                                text: 'DAO ĐÃ MÀI VỚI ĐÁ'
                                font_size: '10sp'
                                color: 0.396, 0.455, 0.545, 1
                                halign: 'left'
                                valign: 'bottom'
                                text_size: self.size
                            Label:
                                id: lbl_stn_knives
                                text: root.stone_knife_count
                                font_size: '20sp'
                                bold: True
                                color: theme.text_main
                                halign: 'left'
                                valign: 'top'
                                text_size: self.size

                # Axis Positions card
                BoxLayout:
                    canvas.before:
                        Color:
                            rgba: theme.bg_panel
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [8,]
                        Color:
                            rgba: theme.border
                        Line:
                            rounded_rectangle: (self.x, self.y, self.width, self.height, 8)
                            width: 1.2
                    size_hint_y: None
                    height: '300dp'
                    orientation: 'vertical'
                    padding: ['12dp', '4dp']
                    spacing: '2dp'

                    Label:
                        text: 'VỊ TRÍ 4 TRỤC'
                        font_size: '11sp'
                        bold: True
                        color: theme.text_mid
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size
                        size_hint_y: None
                        height: '20dp'

                    # Axis A row
                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: '64dp'
                        padding: ['4dp', '2dp']
                        spacing: '8dp'

                        # Letter badge — A (orange)
                        BoxLayout:
                            size_hint_x: None
                            width: '40dp'
                            canvas.before:
                                Color:
                                    rgba: 0.196, 0.118, 0.039, 1
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [6,]
                            Label:
                                text: 'A'
                                font_size: '18sp'
                                bold: True
                                color: 0.984, 0.573, 0.235, 1
                                halign: 'center'
                                valign: 'middle'
                                text_size: self.size

                        # Position value + CPM note
                        BoxLayout:
                            orientation: 'vertical'
                            padding: ['8dp', '0dp']

                            Label:
                                id: pos_a
                                text: root.pos_a
                                font_size: '28sp'
                                bold: True
                                color: theme.text_main
                                halign: 'left'
                                valign: 'bottom'
                                text_size: self.size

                            Label:
                                id: cpm_a
                                text: root.cpm_a
                                font_size: '12sp'
                                color: 0.396, 0.455, 0.545, 1
                                halign: 'left'
                                valign: 'top'
                                text_size: self.size

                    # Axis B row
                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: '64dp'
                        padding: ['4dp', '2dp']
                        spacing: '8dp'

                        # Letter badge — B (purple)
                        BoxLayout:
                            size_hint_x: None
                            width: '40dp'
                            canvas.before:
                                Color:
                                    rgba: 0.161, 0.118, 0.235, 1
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [6,]
                            Label:
                                text: 'B'
                                font_size: '18sp'
                                bold: True
                                color: 0.655, 0.545, 0.984, 1
                                halign: 'center'
                                valign: 'middle'
                                text_size: self.size

                        BoxLayout:
                            orientation: 'vertical'
                            padding: ['8dp', '0dp']

                            Label:
                                id: pos_b
                                text: root.pos_b
                                font_size: '28sp'
                                bold: True
                                color: theme.text_main
                                halign: 'left'
                                valign: 'bottom'
                                text_size: self.size

                            Label:
                                id: cpm_b
                                text: root.cpm_b
                                font_size: '12sp'
                                color: 0.396, 0.455, 0.545, 1
                                halign: 'left'
                                valign: 'top'
                                text_size: self.size

                    # Axis C row
                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: '64dp'
                        padding: ['4dp', '2dp']
                        spacing: '8dp'

                        # Letter badge — C (cyan)
                        BoxLayout:
                            size_hint_x: None
                            width: '40dp'
                            canvas.before:
                                Color:
                                    rgba: 0.039, 0.176, 0.157, 1
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [6,]
                            Label:
                                text: 'C'
                                font_size: '18sp'
                                bold: True
                                color: 0.176, 0.831, 0.749, 1
                                halign: 'center'
                                valign: 'middle'
                                text_size: self.size

                        BoxLayout:
                            orientation: 'vertical'
                            padding: ['8dp', '0dp']

                            Label:
                                id: pos_c
                                text: root.pos_c
                                font_size: '28sp'
                                bold: True
                                color: theme.text_main
                                halign: 'left'
                                valign: 'bottom'
                                text_size: self.size

                            Label:
                                id: cpm_c
                                text: root.cpm_c
                                font_size: '12sp'
                                color: 0.396, 0.455, 0.545, 1
                                halign: 'left'
                                valign: 'top'
                                text_size: self.size

                    # Axis D row — hidden on Serration via _apply_machine_type_widgets
                    BoxLayout:
                        id: pos_d_row
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: '64dp'
                        padding: ['4dp', '2dp']
                        spacing: '8dp'

                        # Letter badge — D (yellow)
                        BoxLayout:
                            size_hint_x: None
                            width: '40dp'
                            canvas.before:
                                Color:
                                    rgba: 0.196, 0.157, 0.039, 1
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [6,]
                            Label:
                                text: 'D'
                                font_size: '18sp'
                                bold: True
                                color: 0.984, 0.749, 0.145, 1
                                halign: 'center'
                                valign: 'middle'
                                text_size: self.size

                        BoxLayout:
                            orientation: 'vertical'
                            padding: ['8dp', '0dp']

                            Label:
                                id: pos_d
                                text: root.pos_d
                                font_size: '28sp'
                                bold: True
                                color: theme.text_main
                                halign: 'left'
                                valign: 'bottom'
                                text_size: self.size

                            Label:
                                id: cpm_d
                                text: root.cpm_d
                                font_size: '12sp'
                                color: 0.396, 0.455, 0.545, 1
                                halign: 'left'
                                valign: 'top'
                                text_size: self.size

                # Spacer — pushes cycle status + axis positions to the top
                Widget:
                    size_hint_y: 1

        # -----------------------------------------------------------------------
        # STONE COMPENSATION BAR (above START GRIND)
        # -----------------------------------------------------------------------
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: '150dp'
            padding: ['12dp', '4dp', '12dp', '2dp']
            spacing: '4dp'

            canvas.before:
                Color:
                    rgba: theme.bg_panel
                Rectangle:
                    pos: self.pos
                    size: self.size

            # Top row: STONE COMPENSATION label + Stone Pos value
            BoxLayout:
                orientation: 'horizontal'
                size_hint_y: None
                height: '40dp'
                spacing: '12dp'

                Label:
                    text: 'BÙ / BỚT ĐÁ'
                    font_size: '14sp'
                    bold: True
                    color: theme.text_mid
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size
                    size_hint_x: 0.5

                Label:
                    id: start_pt_c_label
                    text: root.start_pt_c
                    font_size: '24sp'
                    bold: True
                    color: theme.text_main
                    halign: 'right'
                    valign: 'middle'
                    text_size: self.size
                    size_hint_x: 0.5

            # Bottom: LESS on top, MORE on bottom — stacked vertically
            Button:
                id: less_stone_btn
                text: 'BỚT ĐÁ'
                font_size: '16sp'
                bold: True
                size_hint_y: None
                height: '48dp'
                background_normal: ''
                background_color: 0.15, 0.08, 0.02, 1
                color: 0.984, 0.573, 0.235, 1
                disabled: root.motion_active
                on_release: root.on_less_stone()

            Button:
                id: more_stone_btn
                text: 'THÊM ĐÁ'
                font_size: '16sp'
                bold: True
                size_hint_y: None
                height: '48dp'
                background_normal: ''
                background_color: 0.02, 0.12, 0.06, 1
                color: 0.133, 0.773, 0.369, 1
                disabled: root.motion_active
                on_release: root.on_more_stone()

        # -----------------------------------------------------------------------
        # BOTTOM ACTION BAR
        # -----------------------------------------------------------------------
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: '72dp'
            spacing: '12dp'
            padding: ['12dp', '6dp', '12dp', '6dp']

            canvas.before:
                Color:
                    rgba: theme.bg_panel
                Rectangle:
                    pos: self.pos
                    size: self.size

            Button:
                id: start_grind_btn
                text: 'BẮT ĐẦU MÀI'
                font_size: '16sp'
                bold: True
                size_hint_x: 1
                background_normal: ''
                background_color: 0.09, 0.40, 0.20, 1
                color: 0.733, 0.969, 0.827, 1
                disabled: root.motion_active
                on_release: root.on_start_grind()

            Button:
                id: stop_btn
                text: 'STOP'
                font_size: '16sp'
                bold: True
                size_hint_x: 0.6
                background_normal: ''
                background_down: ''
                background_color: (0.88, 0.06, 0.06, 1) if not self.disabled else (0.3, 0.1, 0.1, 1)
                color: (1, 1, 1, 1) if not self.disabled else (0.5, 0.5, 0.5, 1)
                opacity: 1.0 if root.motion_active else 0.0
                disabled: not root.motion_active
                on_release: root.on_stop()

