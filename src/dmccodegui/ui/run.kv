# RunScreen placeholder

<RunScreen>:
    canvas.before:
        Color:
            rgba: 0.031, 0.047, 0.071, 1
        Rectangle:
            pos: self.pos
            size: self.size
    Label:
        text: 'RUN'
        color: 0.886, 0.910, 0.941, 1
        font_size: '32sp'
        halign: 'center'
        valign: 'middle'
