#:import theme dmccodegui.theme_manager.theme
#:import BCompPanel dmccodegui.screens.serration.widgets.BCompPanel
#:import CCompPanel dmccodegui.screens.serration.widgets.CCompPanel
#:import BCompVisualization dmccodegui.screens.serration.widgets.BCompVisualization
#:import CCompVisualization dmccodegui.screens.serration.widgets.CCompVisualization

<SerrationRunScreen>:
    canvas.before:
        Color:
            rgba: theme.bg_dark
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: ['8dp', '4dp', '8dp', '0dp']
        spacing: '0dp'

        # -----------------------------------------------------------------------
        # Disconnect banner
        # -----------------------------------------------------------------------
        Label:
            text: root.disconnect_banner
            font_size: '16sp'
            bold: True
            color: 1, 1, 1, 1
            size_hint_y: None
            height: '40dp' if root.disconnect_banner else '0dp'
            opacity: 1.0 if root.disconnect_banner else 0.0
            halign: 'center'
            valign: 'middle'
            text_size: self.size
            canvas.before:
                Color:
                    rgba: (0.8, 0.1, 0.1, 1) if root.disconnect_banner else (0, 0, 0, 0)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [4,]

        # -----------------------------------------------------------------------
        # bComp viz (full width)
        # -----------------------------------------------------------------------
        BCompVisualization:
            id: bcomp_viz
            size_hint_y: 1
            canvas.before:
                Color:
                    rgba: theme.bg_panel
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [8, 8, 0, 0]
                Color:
                    rgba: 0.024, 0.714, 0.831, 0.8
                Line:
                    rounded_rectangle: (self.x, self.y, self.width, self.height, 8, 8, 0, 0)
                    width: 1.4

        # bComp elements (full width, horizontal strip)
        BCompPanel:
            id: bcomp_panel
            size_hint_y: 1
            canvas.before:
                Color:
                    rgba: theme.bg_panel
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [0, 0, 8, 8]
                Color:
                    rgba: 0.024, 0.714, 0.831, 0.8
                Line:
                    rounded_rectangle: (self.x, self.y, self.width, self.height, 0, 0, 8, 8)
                    width: 1.4

        # Spacer between bComp and cComp
        Widget:
            size_hint_y: None
            height: '6dp'

        # -----------------------------------------------------------------------
        # cComp viz (full width)
        # -----------------------------------------------------------------------
        CCompVisualization:
            id: ccomp_viz
            size_hint_y: 1
            canvas.before:
                Color:
                    rgba: theme.bg_panel
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [8, 8, 0, 0]
                Color:
                    rgba: (0.980, 0.569, 0.043, 0.10)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [8, 8, 0, 0]
                Color:
                    rgba: (0.980, 0.569, 0.043, 0.3)
                Line:
                    rounded_rectangle: (self.x, self.y, self.width, self.height, 8, 8, 0, 0)
                    width: 1.2

        # cComp elements (full width, horizontal strip)
        CCompPanel:
            id: ccomp_panel
            size_hint_y: 1
            canvas.before:
                Color:
                    rgba: theme.bg_panel
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [0, 0, 8, 8]
                Color:
                    rgba: (0.980, 0.569, 0.043, 0.3)
                Line:
                    rounded_rectangle: (self.x, self.y, self.width, self.height, 0, 0, 8, 8)
                    width: 1.2

        # Spacer
        Widget:
            size_hint_y: None
            height: '6dp'

        # -----------------------------------------------------------------------
        # Bottom row: [Axis Pos + Progress] | [Log + Stone Comp]
        # Fixed height so comp sections above get maximum space
        # -----------------------------------------------------------------------
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: '300dp'
            spacing: '6dp'

            # --- LEFT stack: Axis Positions over Grind Progress ---
            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.3
                spacing: '4dp'

                # Axis Positions (compact)
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: 0.5
                    padding: ['6dp', '2dp']
                    spacing: '1dp'
                    canvas.before:
                        Color:
                            rgba: theme.bg_panel
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [8,]
                        Color:
                            rgba: 0.980, 0.569, 0.043, 0.8
                        Line:
                            rounded_rectangle: (self.x, self.y, self.width, self.height, 8)
                            width: 1.4

                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: 1
                        spacing: '4dp'
                        Label:
                            text: 'A'
                            font_size: '24sp'
                            bold: True
                            color: 0.980, 0.569, 0.043, 1
                            size_hint_x: None
                            width: '28dp'
                            halign: 'center'
                            valign: 'middle'
                            text_size: self.size
                        Label:
                            text: root.pos_a
                            font_size: '28sp'
                            bold: True
                            color: theme.text_main
                            halign: 'right'
                            valign: 'middle'
                            text_size: self.size

                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: 1
                        spacing: '4dp'
                        Label:
                            text: 'B'
                            font_size: '24sp'
                            bold: True
                            color: 0.659, 0.333, 0.965, 1
                            size_hint_x: None
                            width: '28dp'
                            halign: 'center'
                            valign: 'middle'
                            text_size: self.size
                        Label:
                            text: root.pos_b
                            font_size: '28sp'
                            bold: True
                            color: theme.text_main
                            halign: 'right'
                            valign: 'middle'
                            text_size: self.size

                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: 1
                        spacing: '4dp'
                        Label:
                            text: 'C'
                            font_size: '24sp'
                            bold: True
                            color: 0.024, 0.714, 0.831, 1
                            size_hint_x: None
                            width: '28dp'
                            halign: 'center'
                            valign: 'middle'
                            text_size: self.size
                        Label:
                            text: root.pos_c
                            font_size: '28sp'
                            bold: True
                            color: theme.text_main
                            halign: 'right'
                            valign: 'middle'
                            text_size: self.size

                # Grind Progress (compact)
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: 0.5
                    padding: ['6dp', '2dp']
                    spacing: '1dp'
                    canvas.before:
                        Color:
                            rgba: theme.bg_panel
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [8,]
                        Color:
                            rgba: 0.2, 0.9, 0.3, 0.8
                        Line:
                            rounded_rectangle: (self.x, self.y, self.width, self.height, 8)
                            width: 1.4

                    GridLayout:
                        cols: 2
                        spacing: '4dp'
                        size_hint_y: 1

                        BoxLayout:
                            orientation: 'vertical'
                            Label:
                                text: 'Đã chạy'
                                font_size: '16sp'
                                color: 0.396, 0.455, 0.545, 1
                                halign: 'left'
                                valign: 'bottom'
                                text_size: self.size
                            Label:
                                id: lbl_elapsed
                                text: root.cycle_elapsed
                                font_size: '28sp'
                                bold: True
                                color: theme.text_main
                                halign: 'left'
                                valign: 'top'
                                text_size: self.size

                        BoxLayout:
                            orientation: 'vertical'
                            Label:
                                text: 'Còn Lại'
                                font_size: '16sp'
                                color: 0.396, 0.455, 0.545, 1
                                halign: 'left'
                                valign: 'bottom'
                                text_size: self.size
                            Label:
                                id: lbl_eta
                                text: root.cycle_eta
                                font_size: '28sp'
                                bold: True
                                color: theme.text_main
                                halign: 'left'
                                valign: 'top'
                                text_size: self.size

                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: '12dp'
                        spacing: '4dp'

                        ProgressBar:
                            id: cycle_progress
                            min: 0
                            max: 100
                            value: root.cycle_completion_pct
                            size_hint_y: None
                            height: '6dp'
                            pos_hint: {'center_y': 0.5}

                        Label:
                            text: '{0}%'.format(int(root.cycle_completion_pct))
                            font_size: '18sp'
                            bold: True
                            color: 0.396, 0.455, 0.545, 1
                            size_hint_x: None
                            width: '40dp'
                            halign: 'right'
                            valign: 'middle'
                            text_size: self.size

                    GridLayout:
                        cols: 2
                        spacing: '4dp'
                        size_hint_y: None
                        height: '20dp'

                        BoxLayout:
                            orientation: 'horizontal'
                            spacing: '2dp'
                            Label:
                                text: 'Ca:'
                                font_size: '16sp'
                                color: 0.396, 0.455, 0.545, 1
                                size_hint_x: None
                                width: '30dp'
                                halign: 'left'
                                valign: 'middle'
                                text_size: self.size
                            Label:
                                id: lbl_ses_knives
                                text: root.session_knife_count
                                font_size: '24sp'
                                bold: True
                                color: 0.235, 0.639, 0.996, 1
                                halign: 'left'
                                valign: 'middle'
                                text_size: self.size

                        BoxLayout:
                            orientation: 'horizontal'
                            spacing: '2dp'
                            Label:
                                text: 'Đá:'
                                font_size: '16sp'
                                color: 0.396, 0.455, 0.545, 1
                                size_hint_x: None
                                width: '30dp'
                                halign: 'left'
                                valign: 'middle'
                                text_size: self.size
                            Label:
                                id: lbl_stn_knives
                                text: root.stone_knife_count
                                font_size: '24sp'
                                bold: True
                                color: theme.text_main
                                halign: 'left'
                                valign: 'middle'
                                text_size: self.size

            # --- RIGHT stack: Controller Log over Stone Compensation ---
            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.7
                spacing: '4dp'

                # Controller Log
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: 0.8
                    padding: ['6dp', '4dp']
                    spacing: '2dp'
                    canvas.before:
                        Color:
                            rgba: theme.bg_dark
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [8,]
                        Color:
                            rgba: 0.9, 0.2, 0.9, 0.8
                        Line:
                            rounded_rectangle: (self.x, self.y, self.width, self.height, 8)
                            width: 1.4

                    Label:
                        text: 'THÔNG TIN TỪ MÁY'
                        font_size: '18sp'
                        bold: True
                        color: theme.text_mid
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size
                        size_hint_y: None
                        height: '22dp'

                    ScrollView:
                        id: mg_log_scroll
                        do_scroll_x: False

                        Label:
                            text: root.mg_log_text
                            font_size: '20sp'
                            font_name: 'Roboto'
                            color: 0.4, 0.9, 0.4, 1
                            halign: 'left'
                            valign: 'bottom'
                            text_size: self.width, None
                            size_hint_y: None
                            height: max(self.texture_size[1], mg_log_scroll.height)

                # Stone Compensation (B-axis for serration)
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: 0.2
                    padding: ['8dp', '4dp']
                    spacing: '8dp'
                    canvas.before:
                        Color:
                            rgba: theme.bg_panel
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [8,]
                        Color:
                            rgba: 0.9, 0.9, 0.2, 0.8
                        Line:
                            rounded_rectangle: (self.x, self.y, self.width, self.height, 8)
                            width: 1.4

                    # Label + value on left (B-axis stone comp for serration)
                    BoxLayout:
                        orientation: 'vertical'
                        size_hint_x: 0.35
                        Label:
                            text: 'BÙ / BỚT ĐÁ (B)'
                            font_size: '20sp'
                            bold: True
                            color: theme.text_mid
                            halign: 'left'
                            valign: 'bottom'
                            text_size: self.size
                        Label:
                            id: start_pt_b_label
                            text: root.start_pt_c
                            font_size: '24sp'
                            bold: True
                            color: theme.text_main
                            halign: 'left'
                            valign: 'top'
                            text_size: self.size

                    # Buttons on right
                    Button:
                        id: less_stone_btn
                        text: 'BỚT ĐÁ'
                        font_size: '24sp'
                        bold: True
                        size_hint_x: 0.325
                        background_normal: ''
                        background_color: 0.15, 0.08, 0.02, 1
                        color: 0.984, 0.573, 0.235, 1
                        disabled: root.motion_active
                        on_release: root.on_less_stone()

                    Button:
                        id: more_stone_btn
                        text: 'THÊM ĐÁ'
                        font_size: '24sp'
                        bold: True
                        size_hint_x: 0.325
                        background_normal: ''
                        background_color: 0.02, 0.12, 0.06, 1
                        color: 0.133, 0.773, 0.369, 1
                        disabled: root.motion_active
                        on_release: root.on_more_stone()

        # -----------------------------------------------------------------------
        # BOTTOM ACTION BAR
        # -----------------------------------------------------------------------
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: '56dp'
            spacing: '12dp'
            padding: ['4dp', '4dp', '4dp', '4dp']

            canvas.before:
                Color:
                    rgba: theme.bg_panel
                Rectangle:
                    pos: self.pos
                    size: self.size

            Button:
                id: start_grind_btn
                text: 'BẮT ĐẦU MÀI'
                font_size: '16sp'
                bold: True
                size_hint_x: 1
                background_normal: ''
                background_color: 0.09, 0.40, 0.20, 1
                color: 0.733, 0.969, 0.827, 1
                disabled: root.motion_active
                on_release: root.on_start_grind()

            Button:
                id: shutdown_btn
                text: 'TẮT MÁY'
                font_size: '16sp'
                bold: True
                size_hint_x: 0.6
                background_normal: ''
                background_down: ''
                background_color: (0.6, 0.3, 0.0, 1)
                color: (1, 0.9, 0.7, 1)
                disabled: root.motion_active
                on_release: root.on_shutdown()
