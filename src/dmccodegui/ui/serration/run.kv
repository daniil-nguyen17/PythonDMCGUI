#:import theme dmccodegui.theme_manager.theme
#:import BCompPanel dmccodegui.screens.serration.widgets.BCompPanel

<SerrationRunScreen>:
    canvas.before:
        Color:
            rgba: theme.bg_dark
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'

        # -----------------------------------------------------------------------
        # Disconnect banner (visible only when disconnected)
        # -----------------------------------------------------------------------
        Label:
            text: root.disconnect_banner
            font_size: '16sp'
            bold: True
            color: 1, 1, 1, 1
            size_hint_y: None
            height: '40dp' if root.disconnect_banner else '0dp'
            opacity: 1.0 if root.disconnect_banner else 0.0
            halign: 'center'
            valign: 'middle'
            text_size: self.size
            canvas.before:
                Color:
                    rgba: (0.8, 0.1, 0.1, 1) if root.disconnect_banner else (0, 0, 0, 0)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [4,]

        # -----------------------------------------------------------------------
        # Main content: LEFT (50%) + RIGHT (50%)
        # -----------------------------------------------------------------------
        BoxLayout:
            orientation: 'horizontal'
            spacing: '8dp'
            padding: ['8dp', '8dp', '8dp', '4dp']

            # ===================================================================
            # LEFT COLUMN (50%) — plot stub + bComp panel
            # ===================================================================
            BoxLayout:
                size_hint_x: 0.5
                orientation: 'vertical'
                spacing: '8dp'

                # ---------------------------------------------------------------
                # AXIS POSITIONS — 3 axes: A (orange), B (purple), C (cyan)
                # ---------------------------------------------------------------
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: '108dp'
                    padding: ['8dp', '6dp']
                    spacing: '4dp'
                    canvas.before:
                        Color:
                            rgba: theme.bg_panel
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [8,]
                        Color:
                            rgba: theme.border
                        Line:
                            rounded_rectangle: (self.x, self.y, self.width, self.height, 8)
                            width: 1.2

                    # A axis row
                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: '28dp'
                        spacing: '8dp'

                        Label:
                            text: 'A'
                            font_size: '14sp'
                            bold: True
                            color: 0.980, 0.569, 0.043, 1
                            size_hint_x: None
                            width: '20dp'
                            halign: 'center'
                            valign: 'middle'
                            text_size: self.size

                        Label:
                            text: root.pos_a
                            font_size: '18sp'
                            bold: True
                            color: theme.text_main
                            halign: 'right'
                            valign: 'middle'
                            text_size: self.size

                    # B axis row
                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: '28dp'
                        spacing: '8dp'

                        Label:
                            text: 'B'
                            font_size: '14sp'
                            bold: True
                            color: 0.659, 0.333, 0.965, 1
                            size_hint_x: None
                            width: '20dp'
                            halign: 'center'
                            valign: 'middle'
                            text_size: self.size

                        Label:
                            text: root.pos_b
                            font_size: '18sp'
                            bold: True
                            color: theme.text_main
                            halign: 'right'
                            valign: 'middle'
                            text_size: self.size

                    # C axis row
                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: '28dp'
                        spacing: '8dp'

                        Label:
                            text: 'C'
                            font_size: '14sp'
                            bold: True
                            color: 0.024, 0.714, 0.831, 1
                            size_hint_x: None
                            width: '20dp'
                            halign: 'center'
                            valign: 'middle'
                            text_size: self.size

                        Label:
                            text: root.pos_c
                            font_size: '18sp'
                            bold: True
                            color: theme.text_main
                            halign: 'right'
                            valign: 'middle'
                            text_size: self.size

                # ---------------------------------------------------------------
                # PLOT STUB — placeholder until hardware data available
                # ---------------------------------------------------------------
                BoxLayout:
                    id: plot_stub
                    size_hint_y: 0.3
                    canvas.before:
                        Color:
                            rgba: theme.bg_panel
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [8,]
                        Color:
                            rgba: theme.border
                        Line:
                            rounded_rectangle: (self.x, self.y, self.width, self.height, 8)
                            width: 1.2
                    padding: ['12dp', '8dp']

                    Label:
                        text: 'Plot: pending hardware data'
                        font_size: '14sp'
                        color: 0.396, 0.455, 0.545, 1
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size

                # ---------------------------------------------------------------
                # BCOMP PANEL — scrollable editable serration compensation list
                # ---------------------------------------------------------------
                BCompPanel:
                    id: bcomp_panel
                    orientation: 'vertical'
                    size_hint_y: 1
                    canvas.before:
                        Color:
                            rgba: theme.bg_panel
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [8,]
                        Color:
                            rgba: theme.border
                        Line:
                            rounded_rectangle: (self.x, self.y, self.width, self.height, 8)
                            width: 1.2
                    padding: ['8dp', '6dp']
                    spacing: '4dp'

                # ---------------------------------------------------------------
                # GRIND PROGRESS
                # ---------------------------------------------------------------
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: '105dp'
                    padding: ['8dp', '4dp']
                    spacing: '3dp'
                    canvas.before:
                        Color:
                            rgba: theme.bg_panel
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [8,]
                        Color:
                            rgba: theme.border
                        Line:
                            rounded_rectangle: (self.x, self.y, self.width, self.height, 8)
                            width: 1.2

                    Label:
                        text: 'QUA TRINH MAI DAO'
                        font_size: '11sp'
                        bold: True
                        color: theme.text_mid
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size
                        size_hint_y: None
                        height: '18dp'

                    GridLayout:
                        cols: 2
                        spacing: '8dp'
                        size_hint_y: None
                        height: '40dp'

                        BoxLayout:
                            orientation: 'vertical'
                            Label:
                                text: 'THOI GIAN DA CHAY'
                                font_size: '10sp'
                                color: 0.396, 0.455, 0.545, 1
                                halign: 'left'
                                valign: 'bottom'
                                text_size: self.size
                            Label:
                                id: lbl_elapsed
                                text: root.cycle_elapsed
                                font_size: '18sp'
                                bold: True
                                color: theme.text_main
                                halign: 'left'
                                valign: 'top'
                                text_size: self.size

                        BoxLayout:
                            orientation: 'vertical'
                            Label:
                                text: 'THOI GIAN CON LAI'
                                font_size: '10sp'
                                color: 0.396, 0.455, 0.545, 1
                                halign: 'left'
                                valign: 'bottom'
                                text_size: self.size
                            Label:
                                id: lbl_eta
                                text: root.cycle_eta
                                font_size: '18sp'
                                bold: True
                                color: theme.text_main
                                halign: 'left'
                                valign: 'top'
                                text_size: self.size

                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: '24dp'
                        spacing: '8dp'

                        ProgressBar:
                            id: cycle_progress
                            min: 0
                            max: 100
                            value: root.cycle_completion_pct
                            size_hint_y: None
                            height: '10dp'
                            pos_hint: {'center_y': 0.5}

                        Label:
                            text: '{0}%'.format(int(root.cycle_completion_pct))
                            font_size: '11sp'
                            bold: True
                            color: 0.396, 0.455, 0.545, 1
                            size_hint_x: None
                            width: '36dp'
                            halign: 'right'
                            valign: 'middle'
                            text_size: self.size

                    GridLayout:
                        cols: 2
                        spacing: '8dp'
                        size_hint_y: None
                        height: '26dp'

                        BoxLayout:
                            orientation: 'horizontal'
                            spacing: '4dp'
                            Label:
                                text: 'DAO TRONG CA:'
                                font_size: '10sp'
                                color: 0.396, 0.455, 0.545, 1
                                halign: 'left'
                                valign: 'middle'
                                text_size: self.size
                            Label:
                                id: lbl_ses_knives
                                text: root.session_knife_count
                                font_size: '14sp'
                                bold: True
                                color: 0.235, 0.639, 0.996, 1
                                halign: 'left'
                                valign: 'middle'
                                text_size: self.size

                        BoxLayout:
                            orientation: 'horizontal'
                            spacing: '4dp'
                            Label:
                                text: 'DAO VOI DA:'
                                font_size: '10sp'
                                color: 0.396, 0.455, 0.545, 1
                                halign: 'left'
                                valign: 'middle'
                                text_size: self.size
                            Label:
                                id: lbl_stn_knives
                                text: root.stone_knife_count
                                font_size: '14sp'
                                bold: True
                                color: theme.text_main
                                halign: 'left'
                                valign: 'middle'
                                text_size: self.size

            # ===================================================================
            # RIGHT COLUMN (50%) — controller log + stone compensation
            # ===================================================================
            BoxLayout:
                size_hint_x: 0.5
                orientation: 'vertical'
                spacing: '6dp'

                # ---------------------------------------------------------------
                # CONTROLLER LOG (fills available space)
                # ---------------------------------------------------------------
                BoxLayout:
                    orientation: 'vertical'
                    padding: ['8dp', '4dp']
                    spacing: '2dp'
                    canvas.before:
                        Color:
                            rgba: theme.bg_dark
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [8,]
                        Color:
                            rgba: theme.border
                        Line:
                            rounded_rectangle: (self.x, self.y, self.width, self.height, 8)
                            width: 1.2

                    Label:
                        text: 'CONTROLLER LOG'
                        font_size: '11sp'
                        bold: True
                        color: theme.text_mid
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size
                        size_hint_y: None
                        height: '18dp'

                    ScrollView:
                        id: mg_log_scroll
                        do_scroll_x: False

                        Label:
                            text: root.mg_log_text
                            font_size: '28sp'
                            font_name: 'Roboto'
                            color: 0.4, 0.9, 0.4, 1
                            halign: 'left'
                            valign: 'bottom'
                            text_size: self.width, None
                            size_hint_y: None
                            height: max(self.texture_size[1], mg_log_scroll.height)

                # ---------------------------------------------------------------
                # STONE COMPENSATION — more/less stone controls
                # ---------------------------------------------------------------
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: '140dp'
                    padding: ['10dp', '6dp']
                    spacing: '4dp'
                    canvas.before:
                        Color:
                            rgba: theme.bg_panel
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [8,]
                        Color:
                            rgba: theme.border
                        Line:
                            rounded_rectangle: (self.x, self.y, self.width, self.height, 8)
                            width: 1.2

                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: '32dp'
                        spacing: '8dp'

                        Label:
                            text: 'BU / BOT DA'
                            font_size: '12sp'
                            bold: True
                            color: theme.text_mid
                            halign: 'left'
                            valign: 'middle'
                            text_size: self.size
                            size_hint_x: 0.5

                        Label:
                            id: start_pt_c_label
                            text: root.start_pt_c
                            font_size: '20sp'
                            bold: True
                            color: theme.text_main
                            halign: 'right'
                            valign: 'middle'
                            text_size: self.size
                            size_hint_x: 0.5

                    Button:
                        id: less_stone_btn
                        text: 'BOT DA'
                        font_size: '14sp'
                        bold: True
                        size_hint_y: None
                        height: '40dp'
                        background_normal: ''
                        background_color: 0.15, 0.08, 0.02, 1
                        color: 0.984, 0.573, 0.235, 1
                        disabled: root.motion_active
                        on_release: root.on_less_stone()

                    Button:
                        id: more_stone_btn
                        text: 'THEM DA'
                        font_size: '14sp'
                        bold: True
                        size_hint_y: None
                        height: '40dp'
                        background_normal: ''
                        background_color: 0.02, 0.12, 0.06, 1
                        color: 0.133, 0.773, 0.369, 1
                        disabled: root.motion_active
                        on_release: root.on_more_stone()

        # -----------------------------------------------------------------------
        # BOTTOM ACTION BAR (full width)
        # -----------------------------------------------------------------------
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: '72dp'
            spacing: '12dp'
            padding: ['12dp', '6dp', '12dp', '6dp']

            canvas.before:
                Color:
                    rgba: theme.bg_panel
                Rectangle:
                    pos: self.pos
                    size: self.size

            Button:
                id: start_grind_btn
                text: 'BAT DAU MAI'
                font_size: '16sp'
                bold: True
                size_hint_x: 1
                background_normal: ''
                background_color: 0.09, 0.40, 0.20, 1
                color: 0.733, 0.969, 0.827, 1
                disabled: root.motion_active
                on_release: root.on_start_grind()

            Button:
                id: shutdown_btn
                text: 'TAT MAY'
                font_size: '16sp'
                bold: True
                size_hint_x: 0.6
                background_normal: ''
                background_down: ''
                background_color: (0.6, 0.3, 0.0, 1)
                color: (1, 0.9, 0.7, 1)
                disabled: root.motion_active
                on_release: root.on_shutdown()
