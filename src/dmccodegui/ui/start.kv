# Class rules moved to theme.kv to avoid re-declaration warnings

<StartScreen>:
    canvas.before:
        Color:
            rgba: 0.031, 0.047, 0.071, 1
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: 'vertical'
        padding: '2dp'
        spacing: '10dp'

        Label:
            size_hint_y: None
            height: '36dp'
            text: "[b]Chinh Diem Start Cho Truc A B C D[/b]"
            markup: True

        BoxLayout:
            size_hint_y: None
            height: '48dp'
            spacing: '6dp'
            Label:
                text: 'Step'
                size_hint_x: None
                width: '70dp'
            ToggleButton:
                id: step1
                text: 'X1'
                group: 'step'
                state: 'down'
            ToggleButton:
                id: step10
                text: 'X10'
                group: 'step'
            ToggleButton:
                id: step100
                text: 'X100'
                group: 'step'
            Widget:
            Button:
                text: 'Lay Diem Start Ve Man Hinh'
                size_hint_x: None
                width: '280dp'
                on_release: root.loadArrayToPage()
            Button:
                text: 'Luu Diem Start'
                size_hint_x: None
                width: '120dp'
                on_release: root.save_values()

        BoxLayout:
            spacing: '14dp'

            # A (horizontal)
            CardFrame:
                BoxLayout:
                    size_hint_y: None
                    height: '36dp'
                    padding: '6dp'
                    canvas.before:
                        Color:
                            rgba: 0.980, 0.749, 0.043, 0.20
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [6,]
                    Label:
                        text: "[b]Diem Start Truc A[/b]"
                        markup: True
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: 1
                    spacing: '12dp'
                    Widget:
                        size_hint_y: 1
                    Label:
                        size_hint_y: None
                        height: '60dp'
                        text: "Diem Start Truc A"
                        halign: 'center'
                        valign: 'middle'
                        on_size: self.text_size = self.size
                    BoxLayout:
                        size_hint_y: None
                        height: '40dp'
                        padding: '4dp'
                        canvas.before:
                            Color:
                                rgba: 0.051, 0.071, 0.102, 1
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [4,]
                        TextInput:
                            id: a_display
                            readonly: True
                            multiline: False
                            font_size: '18sp'
                            halign: 'center'
                            valign: 'middle'
                            background_color: (0.031, 0.047, 0.071, 1)
                            foreground_color: (0.886, 0.910, 0.941, 1)
                    Label:
                        size_hint_y: None
                        height: '20dp'
                        text: "[color=999999]Value from Controller[/color]"
                        markup: True
                        font_size: '10sp'
                        halign: 'center'
                    HControl:
                        id: a_ctrl
                        left_src:  'arrow-left-red.png'
                        right_src: 'arrow-right-green.png'
                        left_w:  '72dp'
                        right_w: '80dp'
                        left_cb:  lambda: root.adjust_axis('A', -(step1.state=='down' and 1 or step10.state=='down' and 10 or 100))
                        right_cb: lambda: root.adjust_axis('A',  (step1.state=='down' and 1 or step10.state=='down' and 10 or 100))
                    Widget:
                        size_hint_y: 1
            VDivider:

            # B Left (vertical)
            CardFrame:
                BoxLayout:
                    size_hint_y: None
                    height: '36dp'
                    padding: '6dp'
                    canvas.before:
                        Color:
                            rgba: 0.659, 0.333, 0.965, 0.25
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [6,]
                    Label:
                        text: "[b]Diem Start B Trai[/b]"
                        markup: True
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: 1
                    spacing: '12dp'
                    Widget:
                        size_hint_y: 1
                    Label:
                        size_hint_y: None
                        height: '60dp'
                        text: "Diem Start B Trai"
                        halign: 'center'
                        valign: 'middle'
                        on_size: self.text_size = self.size
                    BoxLayout:
                        size_hint_y: None
                        height: '40dp'
                        padding: '4dp'
                        canvas.before:
                            Color:
                                rgba: 0.051, 0.071, 0.102, 1
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [4,]
                        TextInput:
                            id: b_left_display
                            readonly: True
                            multiline: False
                            font_size: '18sp'
                            halign: 'center'
                            valign: 'middle'
                            background_color: (0.031, 0.047, 0.071, 1)
                            foreground_color: (0.886, 0.910, 0.941, 1)
                    Label:
                        size_hint_y: None
                        height: '20dp'
                        text: "[color=999999]Value from Controller[/color]"
                        markup: True
                        font_size: '10sp'
                        halign: 'center'
                    VControl:
                        id: b_left_ctrl
                        up_src:   'arrow-up-green.png'
                        down_src: 'arrow-down-red.png'
                        up_cb:   lambda: root.adjust_axis('B_left',  (step1.state=='down' and 1 or step10.state=='down' and 10 or 100))
                        down_cb: lambda: root.adjust_axis('B_left', -(step1.state=='down' and 1 or step10.state=='down' and 10 or 100))
                    Widget:
                        size_hint_y: 1
            VDivider:

            # B Right (vertical)
            CardFrame:
                BoxLayout:
                    size_hint_y: None
                    height: '36dp'
                    padding: '6dp'
                    canvas.before:
                        Color:
                            rgba: 0.369, 0.510, 0.965, 0.25
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [6,]
                    Label:
                        text: "[b]Diem Start B Phai[/b]"
                        markup: True
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: 1
                    spacing: '12dp'
                    Widget:
                        size_hint_y: 1
                    Label:
                        size_hint_y: None
                        height: '60dp'
                        text: "Diem Start B Phai"
                        halign: 'center'
                        valign: 'middle'
                        on_size: self.text_size = self.size
                    BoxLayout:
                        size_hint_y: None
                        height: '40dp'
                        padding: '4dp'
                        canvas.before:
                            Color:
                                rgba: 0.051, 0.071, 0.102, 1
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [4,]
                        TextInput:
                            id: b_right_display
                            readonly: True
                            multiline: False
                            font_size: '18sp'
                            halign: 'center'
                            valign: 'middle'
                            background_color: (0.031, 0.047, 0.071, 1)
                            foreground_color: (0.886, 0.910, 0.941, 1)
                    Label:
                        size_hint_y: None
                        height: '20dp'
                        text: "[color=999999]Value from Controller[/color]"
                        markup: True
                        font_size: '10sp'
                        halign: 'center'
                    VControl:
                        id: b_right_ctrl
                        up_src:   'arrow-up-green.png'
                        down_src: 'arrow-down-red.png'
                        up_cb:   lambda: root.adjust_axis('B_right',  (step1.state=='down' and 1 or step10.state=='down' and 10 or 100))
                        down_cb: lambda: root.adjust_axis('B_right', -(step1.state=='down' and 1 or step10.state=='down' and 10 or 100))
                    Widget:
                        size_hint_y: 1
            VDivider:

            # C (vertical)
            CardFrame:
                BoxLayout:
                    size_hint_y: None
                    height: '36dp'
                    padding: '6dp'
                    canvas.before:
                        Color:
                            rgba: 0.024, 0.714, 0.831, 0.20
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [6,]
                    Label:
                        text: "[b]Diem Start C[/b]"
                        markup: True
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: 1
                    spacing: '12dp'
                    Widget:
                        size_hint_y: 1
                    Label:
                        size_hint_y: None
                        height: '60dp'
                        text: "Diem Start Truc C"
                        halign: 'center'
                        valign: 'middle'
                        on_size: self.text_size = self.size
                    BoxLayout:
                        size_hint_y: None
                        height: '40dp'
                        padding: '4dp'
                        canvas.before:
                            Color:
                                rgba: 0.051, 0.071, 0.102, 1
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [4,]
                        TextInput:
                            id: c_display
                            readonly: True
                            multiline: False
                            font_size: '18sp'
                            halign: 'center'
                            valign: 'middle'
                            background_color: (0.031, 0.047, 0.071, 1)
                            foreground_color: (0.886, 0.910, 0.941, 1)
                    Label:
                        size_hint_y: None
                        height: '20dp'
                        text: "[color=999999]Value from Controller[/color]"
                        markup: True
                        font_size: '10sp'
                        halign: 'center'
                    VControl:
                        id: c_ctrl
                        up_src:   'arrow-up-green.png'
                        down_src: 'arrow-down-red.png'
                        up_cb:   lambda: root.adjust_axis('C',  (step1.state=='down' and 1 or step10.state=='down' and 10 or 100))
                        down_cb: lambda: root.adjust_axis('C', -(step1.state=='down' and 1 or step10.state=='down' and 10 or 100))
                    Widget:
                        size_hint_y: 1

