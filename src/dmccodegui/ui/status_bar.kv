# StatusBar widget rule
#:import theme dmccodegui.theme_manager.theme

<StatusBar>:
    orientation: 'horizontal'
    size_hint_y: None
    height: '64dp'
    padding: '6dp', '2dp'
    spacing: '6dp'
    canvas.before:
        Color:
            rgba: theme.bg_panel
        Rectangle:
            pos: self.pos
            size: self.size

    # Connection indicator: colored dot + text
    BoxLayout:
        size_hint_x: None
        width: '260dp'
        spacing: '6dp'
        canvas:
            Color:
                rgba: root.connection_color
            Ellipse:
                pos: self.pos[0] + dp(2), self.center_y - dp(5)
                size: dp(10), dp(10)
        Label:
            text: root.connection_text
            color: root.connection_color
            font_size: '22sp'
            halign: 'left'
            valign: 'middle'
            text_size: self.size
            padding_x: '14dp'

    # User / role area (tap to switch user)
    Button:
        id: user_btn
        size_hint_x: None
        width: '280dp'
        background_normal: ''
        background_color: 0, 0, 0, 0
        text: (root.user_text + ' [' + root.role_text + ']') if root.role_text else root.user_text
        color: theme.text_mid
        font_size: '22sp'
        halign: 'left'
        valign: 'middle'
        text_size: self.size
        on_release: root.on_user_tap()

    # Machine type area (tap to change machine type — Setup/Admin only)
    Button:
        id: machine_type_btn
        size_hint_x: None
        width: '260dp'
        size_hint_y: None
        height: '56dp'
        pos_hint: {'center_y': 0.5}
        background_normal: ''
        background_down: ''
        background_color: theme.bg_row
        text: root.machine_type_text
        color: theme.text_mid
        font_size: '17sp'
        halign: 'center'
        valign: 'middle'
        text_size: self.size
        on_release: root.on_machine_type_tap()

    # Banner ticker (fills remaining space)
    Label:
        text: root.banner_text
        color: 1, 0.95, 0.2, 1
        font_size: '23sp'
        halign: 'left'
        valign: 'middle'
        text_size: self.size

    # State label: shows IDLE / GRINDING / SETUP / HOMING / OFFLINE / E-STOP
    Label:
        id: state_label
        text: root.state_text
        color: root.state_color
        size_hint_x: None
        width: '120dp'
        font_size: '20sp'
        bold: True
        halign: 'center'
        valign: 'middle'
        text_size: self.size

    # Theme toggle
    Button:
        text: 'LIGHT' if theme.mode == 'dark' else 'DARK'
        size_hint_x: None
        width: '72dp'
        size_hint_y: None
        height: '56dp'
        pos_hint: {'center_y': 0.5}
        background_normal: ''
        background_down: ''
        background_color: theme.bg_row
        color: theme.text_mid
        font_size: '16sp'
        on_release: app.toggle_theme()

    # RECOVER button (always visible, disabled until DMC program stops)
    Button:
        id: recover_btn
        text: 'RECOVER'
        size_hint_x: None
        width: '110dp'
        size_hint_y: None
        height: '56dp'
        pos_hint: {'center_y': 0.5}
        background_normal: ''
        background_down: ''
        background_color: (0.15, 0.50, 0.20, 1) if not self.disabled else (0.1, 0.15, 0.1, 1)
        color: (1, 1, 1, 1) if not self.disabled else (0.4, 0.4, 0.4, 1)
        font_size: '18sp'
        bold: True
        disabled: not root.recover_enabled
        on_release: app.recover()

    # E-STOP button (always visible, always red)
    Button:
        text: 'E-STOP'
        size_hint_x: None
        width: '100dp'
        size_hint_y: None
        height: '56dp'
        pos_hint: {'center_y': 0.5}
        background_normal: ''
        background_down: ''
        background_color: 0.88, 0.06, 0.06, 1
        color: 1, 1, 1, 1
        font_size: '25sp'
        bold: True
        on_release: app.e_stop()
