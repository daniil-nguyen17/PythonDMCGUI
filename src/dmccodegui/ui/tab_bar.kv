# TabBar widget rule
#:import theme dmccodegui.theme_manager.theme

<TabBar>:
    orientation: 'horizontal'
    size_hint_y: None
    height: '64dp'
    spacing: '2dp'
    padding: '2dp', '2dp'
    canvas.before:
        Color:
            rgba: theme.bg_panel
        Rectangle:
            pos: self.pos
            size: self.size
